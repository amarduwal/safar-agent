# ─── Google Cloud ─────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT_ID=your-gcp-project-id
GOOGLE_CLOUD_REGION=asia-south1
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# ─── Gemini ───────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash

# ─── MongoDB Atlas ────────────────────────────────────────────
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=safar

# ─── Elastic Cloud ────────────────────────────────────────────
ELASTIC_NODE=https://your-deployment.es.us-east-1.aws.found.io
ELASTIC_API_KEY=your-elastic-api-key

# ─── Fivetran ─────────────────────────────────────────────────
FIVETRAN_API_KEY=your-fivetran-api-key
FIVETRAN_API_SECRET=your-fivetran-api-secret

# ─── Arize ────────────────────────────────────────────────────
ARIZE_API_KEY=your-arize-api-key
ARIZE_SPACE_ID=your-arize-space-id
ARIZE_MODEL_ID=safar-severity-classifier

# ─── WhatsApp Business API ────────────────────────────────────
WHATSAPP_TOKEN=your-whatsapp-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_VERIFY_TOKEN=safar_verify_2026
WHATSAPP_BUSINESS_ACCOUNT_ID=your-waba-id

# ─── Security ─────────────────────────────────────────────────
ENCRYPTION_SECRET=32-char-minimum-secret-key-here!!
JWT_SECRET=your-jwt-secret-for-dashboard-auth

# ─── Server ───────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
DASHBOARD_URL=http://localhost:3000

# ─── Dead-man Switch ──────────────────────────────────────────
CHECKIN_INTERVAL_DAYS=7
MISSED_CHECKINS_BEFORE_ESCALATION=2
